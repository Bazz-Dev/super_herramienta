# Copia a .env y completa. Genera AUTH_SECRET con: npx auth secret

# --- Base de datos ---
# Local (dev/tests): archivo SQLite vía better-sqlite3
DATABASE_URL="file:./prisma/dev.db"
# Producción (Vercel/serverless): Turso (libSQL). Ejemplo:
#   DATABASE_URL="libsql://tu-base.turso.io"
#   TURSO_AUTH_TOKEN="<token de Turso>"
# TURSO_AUTH_TOKEN=""

# --- Auth.js v5 ---
AUTH_SECRET=""                       # REQUERIDA. Genera con: npx auth secret
AUTH_URL="http://localhost:3000"     # URL pública (en prod: https://tu-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000" # Igual que AUTH_URL (compatibilidad)
# AUTH_TRUST_HOST="true"             # Necesaria detrás de proxy (Vercel/Railway)

# --- Seed (passwords iniciales — cambiar en producción) ---
# SEED_ADMIN_PASSWORD=""             # Override del password de admin@ingegarchile.cl
# SEED_SEBASTIAN_PASSWORD=""         # Override del password de sgarrido@ingegarchile.cl
# SEED_CRISTIAN_PASSWORD=""          # Override del password de cristian@ingegarchile.cl

# --- GPS / MiCODUS ---
# URL de la plataforma GPS. Se muestra como botón de acceso rápido en Vehículos.
# NO guardes credenciales aquí — solo la URL pública de la plataforma.
NEXT_PUBLIC_GPS_URL="https://www.micodus.net/"

# --- Build en Vercel ---
# Evita que Vercel descargue navegadores de Playwright en el build
# (serverless usa @sparticuz/chromium, no el Chromium empaquetado):
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD="1"
