# Copy to .env and fill in. Generate AUTH_SECRET with: npx auth secret

# SQLite database file (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js v5 secret (REQUIRED) — generate with: npx auth secret
AUTH_SECRET=""

# Base URL of the app
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
