{
  "name": "ingegar-platform",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "node --input-type=module -e \"import { rmSync } from 'fs'; rmSync('tsconfig.tsbuildinfo', { force: true })\" && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test:e2e": "playwright test",
    "test:unit": "node --import tsx --test \"tests/unit/*.test.ts\"",
    "import:flujo": "node --import tsx scripts/import-flujo.ts",
    "db:migrate:prod": "npx tsx --env-file=.env.production.local scripts/turso-migrate.ts",
    "db:migrate:bootstrap": "npx tsx --env-file=.env.production.local scripts/turso-migrate-bootstrap.ts",
    "db:seed:prod": "npx tsx --env-file=.env.production.local scripts/seed-prod.ts",
    "users:tecnico:prod": "npx tsx --env-file=.env.production.local scripts/create-technician-users.ts",
    "users:fix:prod": "npx tsx --env-file=.env.production.local scripts/fix-user-accounts.ts",
    "users:list:prod": "npx tsx --env-file=.env.production.local scripts/_list-users.ts",
    "setup:jb:prod": "npx tsx --env-file=.env.production.local scripts/setup-justburger-portal.ts",
    "setup:jb:branches:prod": "npx tsx --env-file=.env.production.local scripts/setup-jb-branches.ts",
    "setup:hl:prod": "npx tsx --env-file=.env.production.local scripts/setup-happyland.ts",
    "import:jb:prod": "npx tsx --env-file=.env.production.local scripts/import-jb-tickets.ts",
    "import:flujo:prod": "npx tsx --env-file=.env.production.local scripts/import-flujo-prod.ts",
    "fix:portal-slugs:prod": "npx tsx --env-file=.env.production.local scripts/fix-portal-client-slug.ts",
    "sync:r2:prod": "npx tsx --env-file=.env.production.local scripts/sync-r2-docs.ts",
    "sync:r2": "npx tsx --env-file=.env scripts/sync-r2-docs.ts",
    "icons:generate": "node scripts/generate-icons.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@eslint/eslintrc": "^3.3.5",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sparticuz/chromium": "^149.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.7",
    "next-auth": "5.0.0-beta.31",
    "playwright-core": "^1.60.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/web-push": "^3.6.4",
    "canvas": "^3.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.7",
    "exceljs": "^4.4.0",
    "pdf-to-img": "^6.1.0",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
