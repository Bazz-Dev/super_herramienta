// INGEGAR Platform — Prisma schema (Prisma 7, driver adapters)
// Multi-tenant ligero: cada recurso lleva tenantId. El rol "super" (INGEGAR) ve todo.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  super
  supervisor
  client
  tecnico
}

enum AssetStatus {
  available
  in_use
  maintenance
  retired
}

enum AssignmentStatus {
  scheduled
  in_progress
  done
  cancelled
}

enum VehicleStatus {
  active
  maintenance
  retired
}

enum AssigneeRole {
  tecnico
  ayudante
}

enum ContractType {
  indefinido
  plazo_fijo
  ayudante
  no_renovado   // contrato no renovado al vencimiento
  despedido     // desvinculación por decisión de la empresa
}

enum DocType {
  contrato
  epp
  altura
  antecedentes
  licencia
  otro
}

enum ExpenseCategory {
  combustible
  estacionamiento
  materiales
  viatico
  herramienta
  otro
}

enum ExpenseStatus {
  pendiente
  aprobado
  rechazado
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  brandHex  String   @default("#f5b100")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  technicians   Technician[]
  crews         Crew[]
  assets        Asset[]
  vehicles      Vehicle[]
  assignments   Assignment[]
  clients       Client[]
  leaveRequests LeaveRequest[]
  payrolls      Payroll[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique // short alias for login (e.g. "ingegar", "justburger")
  name         String
  passwordHash String
  role         Role     @default(client)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId     String? // set when role = client, scopes portal access
  technicianId String? @unique // set when role = tecnico

  technician        Technician?       @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  ticketsCreated    Ticket[]          @relation("TicketCreatedBy")
  ticketsAssigned   Ticket[]          @relation("TicketAssignedTo")
  ticketHistory     TicketHistory[]
  ticketDocuments   TicketDocument[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  expensesApproved  Expense[]
  clientDocuments   ClientDocument[]
  signaturesCreated SignatureRequest[] @relation("SignatureCreatedBy")
  leaveApprovals    LeaveRequest[]     @relation("LeaveApprovals")

  @@index([tenantId])
  @@map("users")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  type      String   // ticket_new | ticket_update | vehicle_alert | permission_approved
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([tenantId])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// --- Recursos: técnicos, cuadrillas, activos, asignaciones (cronograma) ---

model Technician {
  id        String   @id @default(cuid())
  name      String
  rut       String?
  specialty String? // especialidad / oficio (texto libre)
  email     String?
  phone     String?
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractType    ContractType @default(indefinido)
  contractEndDate DateTime?   // solo para plazo_fijo
  hireDate        DateTime?   // fecha de ingreso a la empresa
  baseSalary      Int?        // sueldo base mensual en CLP
  dailyRate       Int?        // CLP/día — para ayudantes eventuales
  birthDate       DateTime?
  address         String?
  emergencyContact String?
  emergencyPhone  String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  user          User?    // back-relation: User.technicianId → this technician
  crews         Crew[] // M:N implícito
  vehicle       Vehicle? // 1:1 — camioneta asignada (back-relation de Vehicle.technicianId)
  assignees     AssignmentAssignee[] // participaciones en asignaciones (técnico/ayudante)
  documents     TechnicianDocument[]
  ticketCollab  TicketCollaborator[]
  expenses      Expense[]
  signatures    SignatureRequest[]
  leaveRequests LeaveRequest[]
  payrolls      Payroll[]

  @@index([tenantId])
  @@map("technicians")
}

model Vehicle {
  id        String        @id @default(cuid())
  plate     String // patente
  brand     String?
  model     String?
  year      Int?
  status    VehicleStatus @default(active)
  notes     String?

  // Vencimientos y mantenimiento
  revTecnicaExpiry         DateTime?
  soapExpiry               DateTime?
  permisoCirculacionExpiry DateTime?
  lastServiceDate          DateTime?
  nextServiceDate          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 1:1 con técnico (un técnico, una camioneta).
  technicianId String?     @unique
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  assets Asset[] // herramientas en la camioneta (inventario)

  @@index([tenantId])
  @@map("vehicles")
}

enum ClientLabel {
  principal
  ocasional
  prospecto
  inactivo
  proyecto
}

model Client {
  id           String       @id @default(cuid())
  name         String
  rut          String?
  contact      String?
  email        String?
  label        ClientLabel?
  portalSlug   String?      @unique
  portalTheme  String?
  driveFolderId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  ruts        ClientRut[]
  assignments Assignment[]
  branches    Branch[]
  jobs        Job[]
  tickets     Ticket[]
  documents   ClientDocument[]

  @@index([tenantId])
  @@map("clients")
}

model ClientRut {
  id        String   @id @default(cuid())
  rut       String
  label     String?  // ej: "facturación", "casa matriz"
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_ruts")
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  technicians Technician[] // M:N implícito

  @@index([tenantId])
  @@map("crews")
}

model Asset {
  id        String      @id @default(cuid())
  name      String
  code      String?
  category  String?
  status    AssetStatus @default(available)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Camioneta a la que pertenece la herramienta (inventario por camioneta).
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@map("assets")
}

model Assignment {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  start              DateTime
  end                DateTime
  status             AssignmentStatus @default(scheduled)
  permissionRequested Boolean         @default(false) // permiso de sucursal solicitado (verde/amarillo)
  meetingUrl         String? // enlace de reunión (Meet/Zoom), opcional
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  assignees AssignmentAssignee[] // técnicos y ayudantes
  expenses  Expense[]

  @@index([tenantId])
  @@index([start])
  @@index([ticketId])
  @@map("assignments")
}

model AssignmentAssignee {
  id           String       @id @default(cuid())
  role         AssigneeRole @default(tecnico)
  assignmentId String
  assignment   Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  technicianId String
  technician   Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, technicianId])
  @@index([technicianId])
  @@map("assignment_assignees")
}

// --- Flujo de Caja: sucursales, trabajos y costos ---

enum JobType {
  requerimiento
  emergencia
  preventivo
  proyecto
  otro
}

enum JobStatus {
  pendiente
  en_proceso
  ejecutado
  anulado
}

enum CollectionStatus {
  sin_oc
  pendiente_pago
  pagado
}

enum CostCategory {
  materiales
  mano_obra
  subcontrato
  transporte
  otros
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  name      String
  city      String?
  active    Boolean  @default(true)
  jobs      Job[]
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, name])
  @@index([tenantId])
  @@index([clientId])
  @@map("branches")
}

model Job {
  id                String           @id @default(cuid())
  tenantId          String
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  branchId          String
  branch            Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)

  costCenter        String?
  jobNumber         Int?
  importRef         String?          @unique
  quoteRef          String?
  hasTechReport     Boolean          @default(false)
  reportId          String?
  description       String
  type              JobType          @default(requerimiento)
  status            JobStatus        @default(ejecutado)
  executionDate     DateTime?
  technicianId      String?
  notes             String?
  extraNotes        String?

  currency          String           @default("CLP")
  netAmount         Int?
  taxAmount         Int?

  purchaseOrder     String?
  purchaseOrderDate DateTime?
  invoiceNumber     String?
  invoiceDate       DateTime?
  creditDays        Int?
  paymentMethodRaw  String?
  collectionStatus  CollectionStatus @default(sin_oc)
  paymentDate       DateTime?

  costs             JobCost[]
  ticket            Ticket?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([tenantId, clientId])
  @@index([branchId])
  @@map("jobs")
}

model TechnicianDocument {
  id           String     @id @default(cuid())
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  type         DocType    @default(otro)
  label        String?    // nombre personalizado del documento
  fileUrl      String     // ruta relativa: /uploads/docs/[techId]/[filename]
  expiryDate   DateTime?  // vencimiento (ej. contrato plazo fijo, examen altura)
  notes        String?
  uploadedAt   DateTime   @default(now())

  @@index([technicianId])
  @@map("technician_documents")
}

// --- ClientOps: tickets de mantención por cliente ---

enum TicketUrgency {
  emergencia
  urgencia
  no_urgente
  preventivo
}

enum TicketStatus {
  nuevo
  en_revision
  en_ejecucion
  esperando_aprobacion
  resuelto
  cancelado
  fusionado
}

enum ItemStatus {
  pendiente
  en_proceso
  resuelto
}

model Ticket {
  id             String        @id @default(cuid())
  ticketCode     String        @unique
  title          String
  description    String?
  urgency        TicketUrgency @default(no_urgente)
  category       String?
  status         TicketStatus  @default(nuevo)
  otNumber       String?
  estimatedDate  DateTime?
  closedDate     DateTime?
  workSummary    String?
  clientComment  String?
  internalNotes  String?
  folderKey      String?
  parentTicketId String?
  showToClient   Boolean       @default(true)
  tenantId       String
  clientId       String
  branchId       String?
  createdById    String
  assignedToId   String?
  jobId          String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  client        Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  branch        Branch?             @relation(fields: [branchId], references: [id])
  createdBy     User                @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo    User?               @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  job           Job?                @relation(fields: [jobId], references: [id])
  history       TicketHistory[]
  items         TicketItem[]
  documents     TicketDocument[]
  collaborators TicketCollaborator[]
  expenses      Expense[]
  assignments   Assignment[]

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
  @@index([assignedToId])
  @@index([createdById])
  @@index([branchId])
  @@map("tickets")
}

model TicketHistory {
  id         String   @id @default(cuid())
  ticketId   String
  userId     String?
  fromStatus String?
  toStatus   String?
  note       String?
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_history")
}

model TicketItem {
  id          String     @id @default(cuid())
  ticketId    String
  title       String
  description String?
  status      ItemStatus @default(pendiente)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())

  ticket      Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_items")
}

model TicketDocument {
  id           String   @id @default(cuid())
  ticketId     String
  uploadedById String?
  name         String
  fileUrl      String
  mimeType     String?
  uploadedAt   DateTime @default(now())

  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@map("ticket_documents")
}

model TicketCollaborator {
  id           String     @id @default(cuid())
  ticketId     String
  technicianId String

  ticket       Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  technician   Technician @relation(fields: [technicianId], references: [id])

  @@unique([ticketId, technicianId])
  @@index([technicianId])
  @@map("ticket_collaborators")
}

// Gastos de terreno por técnico: combustible, estacionamiento, boletas, viáticos
model Expense {
  id            String          @id @default(cuid())
  tenantId      String
  technicianId  String
  ticketId      String?         // trabajo asociado (opcional)
  assignmentId  String?         // asignación de cronograma asociada (opcional)
  category      ExpenseCategory @default(otro)
  amount        Int             // monto en CLP enteros
  description   String?
  receiptUrl    String?         // URL o data URI del comprobante
  date          DateTime
  status        ExpenseStatus   @default(pendiente)
  approvedById  String?         // usuario que aprobó/rechazó
  rejectedReason String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  technician  Technician   @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  assignment  Assignment?  @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  ticket      Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  approvedBy  User?        @relation(fields: [approvedById], references: [id])

  @@index([technicianId])
  @@index([tenantId, status])
  @@index([ticketId])
  @@index([assignmentId])
  @@map("expenses")
}

// --- Documentos de cliente: propuestas y informes técnicos guardados ---

enum ClientDocType {
  propuesta    // cotización/propuesta comercial
  informe      // informe técnico
  otro
}

model ClientDocument {
  id          String          @id @default(cuid())
  tenantId    String
  clientId    String
  type        ClientDocType   @default(otro)
  title       String
  fileKey     String          // R2 key, o "inline" cuando los datos están en dataJson
  dataJson    String?         // JSON completo del editor (QuoteData | ReportData) — fuente de verdad para re-editar
  metadata    String?         // JSON: { quoteId?, reportId?, amount?, version? }
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([clientId])
  @@map("client_documents")
}

// --- FES interna: firma electrónica simple para técnicos ---

enum SignatureStatus {
  pendiente
  firmado
  rechazado
}

model SignatureRequest {
  id            String          @id @default(cuid())
  tenantId      String
  technicianId  String
  documentType  String          // "contrato" | "anexo" | "acuerdo" | texto libre
  documentTitle String
  documentHash  String          // SHA-256 del contenido del documento
  documentData  String          // JSON con el contenido del documento
  status        SignatureStatus @default(pendiente)
  rutConfirmed  String?         // RUT que confirmó al firmar
  signedAt      DateTime?
  signedIp      String?
  rejectedAt    DateTime?
  rejectedNote  String?
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  technician    Technician      @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  createdBy     User?           @relation("SignatureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([technicianId])
  @@map("signature_requests")
}

model JobCost {
  id          String       @id @default(cuid())
  jobId       String
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category    CostCategory @default(materiales)
  description String?
  amount      Int
  date        DateTime?
  supplier    String?
  documentRef String?
  createdAt   DateTime     @default(now())

  @@index([jobId])
  @@map("job_costs")
}

// ─── RR.HH. ────────────────────────────────────────────────────

enum LeaveType {
  vacaciones
  permiso_sin_goce
  permiso_con_goce
  licencia_medica
  otro
}

enum LeaveStatus {
  pendiente
  aprobado
  rechazado
}

model LeaveRequest {
  id           String      @id @default(cuid())
  tenantId     String
  technicianId String
  type         LeaveType   @default(vacaciones)
  startDate    DateTime
  endDate      DateTime
  days         Int
  status       LeaveStatus @default(pendiente)
  note         String?
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  technician  Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  approvedBy  User?      @relation("LeaveApprovals", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([technicianId])
  @@map("leave_requests")
}

enum PayrollStatus {
  borrador
  emitido
  pagado
}

model Payroll {
  id           String        @id @default(cuid())
  tenantId     String
  technicianId String
  month        Int           // 1–12
  year         Int
  baseSalary   Int           // CLP bruto
  extras       Int           @default(0)   // horas extra, bonos
  deductions   Int           @default(0)   // descuentos
  note         String?
  status       PayrollStatus @default(borrador)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, month, year])
  @@index([tenantId])
  @@map("payrolls")
}
