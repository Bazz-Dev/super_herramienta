// INGEGAR Platform — Prisma schema (Prisma 7, driver adapters)
// Multi-tenant ligero: cada recurso lleva tenantId. El rol "super" (INGEGAR) ve todo.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  super
  supervisor
  client
}

enum AssetStatus {
  available
  in_use
  maintenance
  retired
}

enum AssignmentStatus {
  scheduled
  in_progress
  done
  cancelled
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // ingegar | justburger | loficoffee
  name      String
  brandHex  String   @default("#f5b100")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  technicians Technician[]
  crews       Crew[]
  assets      Asset[]
  assignments Assignment[]
  clients     Client[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(client)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

// --- Recursos: técnicos, cuadrillas, activos, asignaciones (cronograma) ---

model Technician {
  id           String   @id @default(cuid())
  name         String
  rut          String?
  specialty    String? // especialidad / oficio (texto libre)
  email        String?
  phone        String?
  vehiclePlate String? // patente del vehículo / camioneta asignada
  active       Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  crews       Crew[] // M:N implícito
  assignments Assignment[]
  tools       Asset[] // herramientas/activos asignados a su camioneta

  @@index([tenantId])
  @@map("technicians")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  rut       String?
  contact   String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignments Assignment[]

  @@index([tenantId])
  @@map("clients")
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  technicians Technician[] // M:N implícito
  assignments Assignment[]

  @@index([tenantId])
  @@map("crews")
}

model Asset {
  id        String      @id @default(cuid())
  name      String
  code      String?
  category  String?
  status    AssetStatus @default(available)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Camioneta/técnico al que está asignada la herramienta (inventario por camioneta).
  holderId String?
  holder   Technician? @relation(fields: [holderId], references: [id], onDelete: SetNull)

  assignments Assignment[]

  @@index([tenantId])
  @@index([holderId])
  @@map("assets")
}

model Assignment {
  id          String           @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  status      AssignmentStatus @default(scheduled)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  meetingUrl String? // enlace de reunión (Meet/Zoom), opcional

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  crewId       String?
  crew         Crew?       @relation(fields: [crewId], references: [id], onDelete: SetNull)
  assetId      String?
  asset        Asset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([start])
  @@map("assignments")
}
