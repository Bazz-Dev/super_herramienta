// INGEGAR Platform — Prisma schema (Prisma 7, driver adapters)
// Multi-tenant ligero: cada recurso lleva tenantId. El rol "super" (INGEGAR) ve todo.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  super
  supervisor
  client
}

enum AssetStatus {
  available
  in_use
  maintenance
  retired
}

enum AssignmentStatus {
  scheduled
  in_progress
  done
  cancelled
}

enum VehicleStatus {
  active
  maintenance
  retired
}

enum AssigneeRole {
  tecnico
  ayudante
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // ingegar | justburger | loficoffee
  name      String
  brandHex  String   @default("#f5b100")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  technicians Technician[]
  crews       Crew[]
  assets      Asset[]
  vehicles    Vehicle[]
  assignments Assignment[]
  clients     Client[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(client)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

// --- Recursos: técnicos, cuadrillas, activos, asignaciones (cronograma) ---

model Technician {
  id        String   @id @default(cuid())
  name      String
  rut       String?
  specialty String? // especialidad / oficio (texto libre)
  email     String?
  phone     String?
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  crews     Crew[] // M:N implícito
  vehicle   Vehicle? // 1:1 — camioneta asignada (back-relation de Vehicle.technicianId)
  assignees AssignmentAssignee[] // participaciones en asignaciones (técnico/ayudante)

  @@index([tenantId])
  @@map("technicians")
}

model Vehicle {
  id        String        @id @default(cuid())
  plate     String // patente
  brand     String?
  model     String?
  year      Int?
  status    VehicleStatus @default(active)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // 1:1 con técnico (un técnico, una camioneta).
  technicianId String?     @unique
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  assets Asset[] // herramientas en la camioneta (inventario)

  @@index([tenantId])
  @@map("vehicles")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  rut       String?
  contact   String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignments Assignment[]

  @@index([tenantId])
  @@map("clients")
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  technicians Technician[] // M:N implícito

  @@index([tenantId])
  @@map("crews")
}

model Asset {
  id        String      @id @default(cuid())
  name      String
  code      String?
  category  String?
  status    AssetStatus @default(available)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Camioneta a la que pertenece la herramienta (inventario por camioneta).
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@map("assets")
}

model Assignment {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  start              DateTime
  end                DateTime
  status             AssignmentStatus @default(scheduled)
  permissionRequested Boolean         @default(false) // permiso de sucursal solicitado (verde/amarillo)
  meetingUrl         String? // enlace de reunión (Meet/Zoom), opcional
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  assignees AssignmentAssignee[] // técnicos y ayudantes

  @@index([tenantId])
  @@index([start])
  @@map("assignments")
}

model AssignmentAssignee {
  id           String       @id @default(cuid())
  role         AssigneeRole @default(tecnico)
  assignmentId String
  assignment   Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  technicianId String
  technician   Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, technicianId])
  @@index([technicianId])
  @@map("assignment_assignees")
}
